# ============================================================================
# FHENIX MARKETS - Vercel Environment Variables Template
# ============================================================================
# Copy these to Vercel Dashboard → Settings → Environment Variables
# ============================================================================

# =========================
# APP CONFIGURATION
# =========================
VITE_APP_NAME=Fhenix Markets
VITE_APP_DESCRIPTION=Privacy-Preserving Prediction Markets with FHE on Ethereum
VITE_APP_URL=https://your-project.vercel.app

# =========================
# FEATURE FLAGS
# =========================
VITE_ENABLE_CREATE_MARKET=true
VITE_ENABLE_BETTING=true
VITE_SHOW_TESTNET_BANNER=true
VITE_DEBUG=false

# =========================
# SUPABASE (Market data persistence)
# =========================
# Required tables: user_bets, pending_bets, commitment_records, market_registry
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =========================
# PRIVY (Wallet authentication)
# =========================
VITE_PRIVY_APP_ID=your-privy-app-id

# =========================
# OPTIONAL: ANALYTICS & MONITORING
# =========================
# VITE_ANALYTICS_ID=
# VITE_SENTRY_DSN=
