# Private key of the deployer account (without 0x prefix works too)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Sepolia RPC (optional, defaults to publicnode.com)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

