# ============================================================================
# VEILED MARKETS - Frontend Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# =========================
# NETWORK CONFIGURATION
# =========================

# Network to connect to: testnet | mainnet
VITE_NETWORK=testnet

# Aleo RPC endpoint (optional - uses default if not set)
VITE_ALEO_RPC_URL=https://api.explorer.provable.com/v1/testnet

# Block explorer URL
VITE_EXPLORER_URL=https://testnet.explorer.provable.com

# =========================
# PROGRAM CONFIGURATION
# =========================

# Deployed program IDs
VITE_PROGRAM_ID=veiled_markets_v35.aleo
VITE_CREDITS_PROGRAM_ID=credits.aleo
VITE_USDCX_PROGRAM_ID=test_usdcx_stablecoin.aleo
VITE_USAD_PROGRAM_ID=veiled_markets_usad_v12.aleo
VITE_USDCX_MARKET_PROGRAM_ID=veiled_markets_usdcx_v5.aleo
VITE_GOVERNANCE_PROGRAM_ID=veiled_governance_v4.aleo

# =========================
# WALLET CONFIGURATION
# =========================

# Enable demo mode (allows testing without real wallet)
VITE_ENABLE_DEMO_MODE=true

# Default wallet to suggest: puzzle | leo
VITE_DEFAULT_WALLET=puzzle

# =========================
# DEVELOPMENT KEYS (LOCAL TESTING ONLY!)
# =========================
# WARNING: NEVER use real/mainnet keys here!
# These are exposed to the browser and ONLY for local development
# Generate test keys with: snarkos account new
#
# VITE_DEV_PRIVATE_KEY=APrivateKey1...
# VITE_DEV_VIEW_KEY=AViewKey1...
# VITE_DEV_ADDRESS=aleo1...

# =========================
# FEATURE FLAGS
# =========================

# Enable market creation (set false to disable in production)
VITE_ENABLE_CREATE_MARKET=true

# Enable betting (set false to pause betting)
VITE_ENABLE_BETTING=true

# Show testnet warning banner
VITE_SHOW_TESTNET_BANNER=true

# Enable debug logging
VITE_DEBUG=false

# =========================
# SUPABASE (Cross-device bet persistence)
# =========================

# Supabase project URL and anon key (public, safe for browser)
# Get from: https://supabase.com → Project Settings → API
# Required tables: user_bets, pending_bets, commitment_records, market_registry
# Run the SQL from supabase-schema.sql to create them
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =========================
# IPFS / PINATA (Market Metadata Storage)
# =========================

# Pinata JWT for uploading market metadata to IPFS
# Get from: https://app.pinata.cloud/developers/api-keys
# Market metadata is public, so this key is safe for browser use
# Free tier: 1GB storage, 100 pins
VITE_PINATA_JWT=your-pinata-jwt

# Pinata dedicated gateway (optional - uses public gateway as fallback)
# VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# =========================
# API KEYS (Optional)
# =========================

# Analytics (if using)
# VITE_ANALYTICS_ID=

# Error tracking (if using Sentry)
# VITE_SENTRY_DSN=

# =========================
# APP CONFIGURATION
# =========================

# App name (shown in wallet connection requests)
VITE_APP_NAME=Veiled Markets

# App description
VITE_APP_DESCRIPTION=Privacy-Preserving Prediction Markets on Aleo

# App URL (for metadata)
VITE_APP_URL=https://veiled.markets
