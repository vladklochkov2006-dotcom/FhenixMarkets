# ============================================================================
# FHENIX MARKETS - Root Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values
# ============================================================================

# =========================
# ETHEREUM CREDENTIALS
# =========================

# Your private key for contract deployment (used by Hardhat)
# IMPORTANT: Never commit your actual private key!
PRIVATE_KEY=0x...

# =========================
# NETWORK CONFIGURATION
# =========================

# Sepolia RPC URL (Alchemy, Infura, or public)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=

# =========================
# DEVELOPMENT
# =========================

# Enable verbose logging
DEBUG=false
